}


### GET POSTS
GET {{host}}/posts/posts/
Content-Type: application/json


### POST Follow
POST {{host}}/users/follow/2/
Authorization: Bearer {{varvar_token}}


### DELETE Follow
DELETE {{host}}/users/follow/2/
Authorization: Bearer {{varvar_token}}


### GET Following POSTS
GET {{host}}/posts/following/
Authorization: Bearer {{ access_token }}


### GET Friends POSTS
GET {{host}}/posts/friends/
Authorization: Bearer {{ access_token }}


### GET Saved POSTS
GET {{host}}/posts/posts/?saved=true/
Authorization: Bearer {{ access_token }}


### GET Reposts POSTS
GET {{host}}/posts/posts/?reposts=true/
Authorization: Bearer {{ access_token }}


### POST Repost
POST {{host}}/posts/posts/6/repost_toggle/
Authorization: Bearer {{access_token}}


### GET ROOMS
GET {{host}}/chat/rooms/
Authorization: Bearer {{access_token}}


### GET MESSAGES
GET {{host}}/chat/messages/50/
Authorization: Bearer {{access_token}}

### CREATE ROOM
POST {{host}}/chat/rooms/create/
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "participant_ids": [6],
  "room_type": "direct"
}